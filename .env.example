# === RPC principal — Base (Alchemy ou similar, obrigatório) ===
# ALCHEMY_WS_URL — WebSocket removido; Alchemy usado apenas como HTTP RPC fallback via HTTP_RPC_URL
HTTP_RPC_URL=https://mainnet.base.org
HTTP_RPC_URL_2=https://your-node-provider.base-mainnet.example.com/your-api-key
HTTP_RPC_URL_3=https://base-rpc.publicnode.com

# === RPCs por chain — provider principal (Alchemy / pago) ===
# Aceita múltiplas URLs separadas por vírgula (fallback automático)
ETH_HTTP_RPC_URL=https://your-provider.eth-mainnet.example.com/key,https://eth.llamarpc.com
BSC_HTTP_RPC_URL=https://your-provider.bnb-mainnet.example.com/key,https://bsc-dataseed.binance.org
ARB_HTTP_RPC_URL=https://your-provider.arb-mainnet.example.com/key,https://arb1.arbitrum.io/rpc
POLYGON_HTTP_RPC_URL=https://your-provider.polygon-mainnet.example.com/key,https://rpc.ankr.com/polygon
AVAX_HTTP_RPC_URL=https://your-provider.avax-mainnet.example.com/key,https://api.avax.network/ext/bc/C/rpc
HL_L1_HTTP_RPC_URL=https://your-provider.hyperliquid-mainnet.example.com/key,https://rpc.hyperliquid.xyz/evm
MULTICALL3_ENABLED=true

# === RPCs gratuitos para leitura de LP (sem consumir Alchemy) ===
# getLpProvider() usa estes para positions() + collect.staticCall()
# Se vazio, faz fallback para o provider principal da chain
LP_FREE_BASE_RPC_URL=https://base.publicnode.com,https://base.drpc.org,https://1rpc.io/base
LP_FREE_ETH_RPC_URL=https://eth.publicnode.com,https://ethereum.drpc.org,https://1rpc.io/eth
LP_FREE_BSC_RPC_URL=https://bsc.publicnode.com,https://bsc.drpc.org,https://1rpc.io/bnb
LP_FREE_ARB_RPC_URL=https://arbitrum.publicnode.com,https://arbitrum.drpc.org,https://1rpc.io/arb
LP_FREE_POLYGON_RPC_URL=https://polygon.publicnode.com,https://polygon.drpc.org,https://1rpc.io/matic
LP_FREE_AVAX_RPC_URL=https://avalanche.publicnode.com/ext/bc/C/rpc,https://avalanche.drpc.org,https://1rpc.io/avax
LP_FREE_HL_L1_RPC_URL=https://rpc.hyperliquid.xyz/evm

# === Ciclos ===
# DEPRECATED: CYCLE_MODE — WebSocket/block-mode removido; apenas timer é suportado
# DEPRECATED: CYCLE_MODE=block|timer
CYCLE_INTERVAL_MIN=720
# Ciclo LP+PnL (leitura de liquidez/fees via RPCs gratuitos + HL API)
LP_READ_INTERVAL_MIN=5
LP_READ_INTER_USER_DELAY_MS=5000

# === Mode ===
DRY_RUN=true

# === Dashboard ===
DASHBOARD_PORT=3001

# === Strategy defaults (sobrescritos por posição na ativação via dashboard) ===
HEDGE_FLOOR=0.90
MIN_NOTIONAL_USD=10
MAX_NOTIONAL_USD=100000
MAX_DAILY_REBALANCES=150
# Intervalo entre rebalances periódicos (minutos) — serve também como cooldown mínimo
REBALANCE_INTERVAL_MIN=720
EMERGENCY_PRICE_MOVEMENT_THRESHOLD=0.15
# DEPRECATED: BLOCK_THROTTLE — WebSocket/block-mode removido
# BLOCK_THROTTLE=50

# === Hyperliquid ===
# Taxa taker (0.000432 = 0.0432%)
HL_TAKER_FEE=0.000432

# === Logging ===
LOG_LEVEL=info                    # debug | info | warn | error

# === Loki (Grafana Cloud ou self-hosted) ===
LOKI_ENABLED=false
LOKI_URL=https://logs-prod-xxx.grafana.net
LOKI_TENANT_ID=                   # Grafana Cloud: seu tenant ID
LOKI_USERNAME=                    # Grafana Cloud: user ID numérico
LOKI_PASSWORD=                    # Grafana Cloud: API key com role Editor

# === Telegram Alerts ===
# 1. Fale com @BotFather no Telegram → /newbot → copie o token
# 2. Envie qualquer mensagem para o bot criado
# 3. Acesse https://api.telegram.org/bot<TOKEN>/getUpdates → copie chat.id
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# === Supabase (opcional — deixar em branco para desativar persistência) ===
SUPABASE_URL=
SUPABASE_KEY=
